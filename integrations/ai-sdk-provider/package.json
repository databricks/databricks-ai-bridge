{
  "name": "@databricks/ai-sdk-provider",
  "version": "0.5.2-test.0",
  "description": "Databricks provider for Vercel AI SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:genie:live": "RUN_GENIE_LIVE_TEST=1 vitest run tests/genie-live-smoke.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "format:fix": "prettier --write 'src/**/*.ts'",
    "check-package": "attw --pack . --format table --ignore-rules no-resolution",
    "prepublishOnly": "npm run clean && npm run build && npm run test && npm run lint && npm run check-package"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@ai-sdk/provider": "^3.0.5",
    "@ai-sdk/provider-utils": "^4.0.10",
    "ai": "^6.0.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.5",
    "@ai-sdk/provider-utils": "^4.0.10",
    "@arethetypeswrong/cli": "0.18.2",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "4.1.4",
    "ai": "^6.0.0",
    "dotenv": "^17.4.2",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "msw": "2.13.2",
    "prettier": "3.8.2",
    "tsdown": "0.21.7",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  },
  "overrides": {
    "ajv": "6.14.0",
    "flatted": "3.4.2",
    "minimatch@3": {
      "brace-expansion": "1.1.14"
    },
    "minimatch@9": {
      "brace-expansion": "2.0.3"
    },
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "vite": {
      "picomatch": "4.0.4"
    },
    "tinyglobby": {
      "picomatch": "4.0.4"
    },
    "unplugin": {
      "picomatch": "4.0.4"
    },
    "vitest": {
      "picomatch": "4.0.4"
    }
  },
  "author": {
    "name": "Databricks",
    "email": "agent-feedback@databricks.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/databricks/databricks-ai-bridge.git",
    "directory": "integrations/ai-sdk-provider"
  },
  "homepage": "https://github.com/databricks/databricks-ai-bridge/tree/main/integrations/ai-sdk-provider",
  "bugs": {
    "url": "https://github.com/databricks/databricks-ai-bridge/issues"
  },
  "keywords": [
    "databricks",
    "ai",
    "ai-sdk",
    "vercel",
    "llm",
    "language-model",
    "agent",
    "mcp"
  ],
  "license": "Databricks License"
}
